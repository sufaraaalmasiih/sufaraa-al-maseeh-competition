rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function teamDocExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/teams/$(request.auth.uid));
    }

    function teamRegisteredInCompetition(competitionId) {
      return isSignedIn()
        && (
          exists(/databases/$(database)/documents/teams/$(request.auth.uid))
          || exists(/databases/$(database)/documents/competitions/$(competitionId)/teamStates/$(request.auth.uid))
        );
    }

    function staffDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function staffDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isFacilitator() {
      return isSignedIn()
        && staffDocExists()
        && staffDoc().data.role in ['facilitator', 'super_admin'];
    }

    function isSuperAdmin() {
      return isSignedIn()
        && staffDocExists()
        && staffDoc().data.role == 'super_admin';
    }

    // حساب مدرب منفصل (للعرض فقط) — مرتبط بفريق عبر coaches/{uid}.linkedTeamId.
    function isCoach() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/coaches/$(request.auth.uid));
    }

    function coachLinkedTeamId() {
      return get(/databases/$(database)/documents/coaches/$(request.auth.uid)).data.linkedTeamId;
    }

    function boundedScoreDelta(oldScore, newScore) {
      // الحد الأعلى 100: يغطّي م3 الصعب (45) وتجاوزات النقاط لكل سؤال (حتى 100).
      return (newScore - oldScore) >= -200
        && (newScore - oldScore) <= 100;
    }

    function teamStateScoreUpdateAllowed() {
      let oldTotal = resource.data.totalScore is number ? resource.data.totalScore : 0;
      let newTotal = request.resource.data.totalScore is number
        ? request.resource.data.totalScore
        : oldTotal;
      return boundedScoreDelta(oldTotal, newTotal);
    }

    function teamAnswerPayloadAllowed(competitionId) {
      let data = request.resource.data;
      return teamRegisteredInCompetition(competitionId)
        && !isCoach()
        && data.teamId == request.auth.uid
        && data.confirmed == true
        && data.isCorrect is bool
        && data.pointsDelta is number
        && data.pointsDelta >= -200
        && data.pointsDelta <= 100;
    }

    function teamAnswerCreateAllowed(competitionId) {
      return teamAnswerPayloadAllowed(competitionId);
    }

    function teamAnswerUpdateAllowed(competitionId) {
      return resource.data.teamId == request.auth.uid
        && teamAnswerPayloadAllowed(competitionId);
    }

    // Firestore && and || are NOT short-circuit — never use resource.data when resource may be null.
    function answerVisibleToAudience() {
      return resource != null ? resource.data.visibleToAudience == true : false;
    }

    function answerOwnedByAuthUser() {
      return resource == null ? true : resource.data.teamId == request.auth.uid;
    }

    function answerReadable(competitionId) {
      return isFacilitator()
        || answerVisibleToAudience()
        || (teamRegisteredInCompetition(competitionId) && answerOwnedByAuthUser())
        // المدرب المرتبط يقرأ إجابات فريقه (للمتابعة) — لكنه لا يكتب أبداً.
        || (isCoach() && resource != null && resource.data.teamId == coachLinkedTeamId());
    }

    // Team profile (registration)
    match /teams/{uid} {
      allow read: if isOwner(uid) || isFacilitator();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isFacilitator();
      allow delete: if isFacilitator();
    }

    // Coach accounts (separate, view-only, linked to a team). NEVER write answers.
    match /coaches/{coachUid} {
      allow read: if isOwner(coachUid) || isFacilitator();
      allow create: if isOwner(coachUid)
        && request.resource.data.role == 'coach'
        && request.resource.data.linkedTeamId is string;
      allow update: if isOwner(coachUid) || isFacilitator();
      allow delete: if isOwner(coachUid) || isFacilitator();
    }

    // Staff accounts (facilitator / super_admin / viewer)
    match /users/{uid} {
      allow read: if isOwner(uid) || isFacilitator();
      allow create, update, delete: if isSuperAdmin();
    }

    function teamStateProgressUpdateAllowed() {
      let oldTotal = resource.data.totalScore is number ? resource.data.totalScore : 0;
      let newTotal = request.resource.data.totalScore is number
        ? request.resource.data.totalScore
        : oldTotal;
      return oldTotal == newTotal;
    }

    function stage3OwnerSelectingQuestion() {
      let prev = resource.data;
      let next = request.resource.data;
      return teamDocExists()
        && prev.status == 'stage3_board'
        && prev.stage3OwnerTeamId == request.auth.uid
        && next.status == 'stage3_question_open'
        && next.currentStage == 'stage3'
        && next.stage3OwnerTeamId == prev.stage3OwnerTeamId
        && next.competitionFrozen == prev.competitionFrozen;
    }

    function teamStage3AnsweringTimerAllowed(competitionId) {
      let gameFlow = get(/databases/$(database)/documents/competitions/$(competitionId)/system/gameFlow);
      let data = request.resource.data;
      return teamDocExists()
        && gameFlow.data.stage3OwnerTeamId == request.auth.uid
        && gameFlow.data.status in ['stage3_board', 'stage3_question_open']
        && data.stage == 'stage3'
        && data.purpose == 'answering'
        && data.active == true
        && data.durationSeconds is int
        && data.durationSeconds > 0
        && data.durationSeconds <= 120;
    }

    // Competition data
    match /competitions/{competitionId} {
      // Public read for audience screens (gameFlow + timer)
      match /system/{docId} {
        allow read: if true;
        allow write: if isFacilitator()
          || (docId == 'gameFlow' && stage3OwnerSelectingQuestion())
          || (docId == 'timer' && teamStage3AnsweringTimerAllowed(competitionId))
          || (docId == 'clockSync' && isSignedIn());
      }

      // Rankings visible to audience; teams update own doc with bounded score deltas
      match /teamStates/{teamId} {
        allow read: if true;
        allow create: if isOwner(teamId) && !isCoach();
        allow update: if isFacilitator()
          || (isOwner(teamId) && !isCoach() && (teamStateScoreUpdateAllowed() || teamStateProgressUpdateAllowed()));
        allow delete: if isFacilitator();
      }

      // Answers: teams submit bounded payloads; audience reads revealed answers
      match /answers/{answerId} {
        allow read: if answerReadable(competitionId);
        allow create: if isFacilitator() || teamAnswerCreateAllowed(competitionId);
        allow update: if isFacilitator() || teamAnswerUpdateAllowed(competitionId);
        allow delete: if isFacilitator();
      }

      // Session history + edit log (facilitators only — full archive of all teams).
      match /history/{sessionId} {
        allow read, write: if isFacilitator();
      }

      // Per-team archive copies. Read: facilitators (all) + the owning team only
      // (privacy — a team never sees another team's archived results).
      // Write: facilitators only (written when results are saved).
      match /teamArchives/{archiveId} {
        allow read: if isFacilitator()
          || (isSignedIn() && resource.data.teamId == request.auth.uid);
        allow write: if isFacilitator();
      }

      // Coach/team objections on questions.
      // Create: a signed-in team for itself. Read: facilitators (all) + the owning team.
      // Update/delete: facilitators only (mark reviewed / cleanup).
      match /objections/{objectionId} {
        allow read: if isFacilitator()
          || (isSignedIn() && resource.data.teamId == request.auth.uid);
        allow create: if isSignedIn()
          && request.resource.data.teamId == request.auth.uid;
        allow update, delete: if isFacilitator();
      }

      // Audit trail (facilitator only)
      match /auditLog/{logId} {
        allow read, create: if isFacilitator();
        allow update, delete: if false;
      }

      // Question banks (teams read during play; facilitator edits)
      match /questionBanks/{bankId} {
        allow read: if isSignedIn();
        allow write: if isFacilitator();

        match /archives/{archiveId} {
          allow read, write: if isFacilitator();
        }
      }
    }
  }
}
